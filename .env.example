JWT_SECRET=change-me-to-a-long-random-string
ADMIN_EMAIL=admin@portfolio.local
ADMIN_PASSWORD=your-secure-password

# Production (nginx + Let's Encrypt)
DOMAIN=portfolio.example.com
ADMIN_DOMAIN=admin.portfolio.example.com
CERTBOT_EMAIL=you@example.com
# Set to 1 for testing (avoids rate limits). Browser will show "not secure"!
CERTBOT_STAGING=0
# Set to 1 to re-issue certificate (e.g. staging → production)
CERTBOT_FORCE_RENEW=0

# Yandex Metrika (optional). Only on your server in .env — not committed to git.
# Leave empty locally / in forks to disable analytics.
YM_COUNTER_ID=
